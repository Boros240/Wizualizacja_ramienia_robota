<?xml version="1.0"?>
<robot name="proste_ramie">

  <!-- ═══════════════════════════════════════════════════
       MATERIAŁY / KOLORY
  ═══════════════════════════════════════════════════ -->

  <!-- Stalowo-srebrny korpus -->
  <material name="steel">
    <color rgba="0.75 0.78 0.82 1.0"/>
  </material>

  <!-- Ciemnografitowe ramiona -->
  <material name="dark_metal">
    <color rgba="0.22 0.24 0.28 1.0"/>
  </material>

  <!-- Pomarańczowe akcenty (stawy, końcówka) -->
  <material name="accent_orange">
    <color rgba="0.95 0.45 0.05 1.0"/>
  </material>

  <!-- Żółto-zielony chwytak -->
  <material name="gripper_color">
    <color rgba="0.20 0.75 0.30 1.0"/>
  </material>

  <!-- Czarny pasek dekoracyjny -->
  <material name="black">
    <color rgba="0.10 0.10 0.12 1.0"/>
  </material>

  <!-- Jasny szary dla kul stawowych -->
  <material name="joint_ball">
    <color rgba="0.85 0.45 0.10 1.0"/>
  </material>


  <!-- ═══════════════════════════════════════════════════
       BAZA  (gruby walec + kula przejściowa)
  ═══════════════════════════════════════════════════ -->

  <link name="base_link">
    <!-- główna tarcza -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.16" radius="0.36"/>
      </geometry>
      <material name="steel"/>
    </visual>
    <!-- pierścień ozdobny (węższy, wyżej) -->
    <visual>
      <origin xyz="0 0 0.11" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.06" radius="0.24"/>
      </geometry>
      <material name="accent_orange"/>
    </visual>
    <!-- kula przejścia do link1 -->
    <visual>
      <origin xyz="0 0 0.14" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.14"/>
      </geometry>
      <material name="joint_ball"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.16" radius="0.36"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="80"/>
      <inertia ixx="4.8" ixy="0" ixz="0" iyy="4.8" iyz="0" izz="6.4"/>
    </inertial>
  </link>


  <!-- ═══════════════════════════════════════════════════
       JOINT 1 – obrót wokół Z (baza → link1)
  ═══════════════════════════════════════════════════ -->

  <joint name="joint1" type="revolute">
    <parent link="base_link"/>
    <child  link="link1"/>
    <origin xyz="0 0 0.14" rpy="0 0 0"/>
    <axis   xyz="0 0 2"/>
    <limit  lower="-2.618" upper="2.618" effort="300" velocity="1.2"/>
    <dynamics damping="8" friction="1.6"/>
  </joint>


  <!-- ═══════════════════════════════════════════════════
       LINK 1 – pierwsze (najdłuższe) ramię
  ═══════════════════════════════════════════════════ -->

  <!-- Element pionowy SKRÓCONY (0.76 -> 0.44), by „bark" (joint2) znalazł
       się niżej i ramię realnie sięgało kostki leżącej na podłodze. -->
  <link name="link1">
    <!-- główny trzon -->
    <visual>
      <origin xyz="0 0 0.24" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.44" radius="0.09"/>
      </geometry>
      <material name="dark_metal"/>
    </visual>
    <!-- ozdobny środkowy pierścień -->
    <visual>
      <origin xyz="0 0 0.24" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.08" radius="0.11"/>
      </geometry>
      <material name="accent_orange"/>
    </visual>
    <!-- kula u góry (przejście do joint2) -->
    <visual>
      <origin xyz="0 0 0.46" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.11"/>
      </geometry>
      <material name="joint_ball"/>
    </visual>

    <collision>
      <origin xyz="0 0 0.24" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.44" radius="0.09"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.24" rpy="0 0 0"/>
      <mass value="16"/>
      <inertia ixx="0.96" ixy="0" ixz="0" iyy="0.96" iyz="0" izz="0.128"/>
    </inertial>
  </link>


  <!-- ═══════════════════════════════════════════════════
       JOINT 2 – zgięcie wokół Y
  ═══════════════════════════════════════════════════ -->

  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child  link="link2"/>
    <origin xyz="0 0 0.46" rpy="0 0 0"/>
    <axis   xyz="0 2 0"/>
    <limit  lower="-1.57" upper="1.57" effort="240" velocity="1.2"/>
    <dynamics damping="6.4" friction="1.6"/>
  </joint>


  <!-- ═══════════════════════════════════════════════════
       LINK 2 – środkowe ramię
  ═══════════════════════════════════════════════════ -->

  <link name="link2">
    <visual>
      <origin xyz="0 0 0.28" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.52" radius="0.072"/>
      </geometry>
      <material name="steel"/>
    </visual>
    <!-- ozdobny pierścień -->
    <visual>
      <origin xyz="0 0 0.28" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.06" radius="0.092"/>
      </geometry>
      <material name="black"/>
    </visual>
    <!-- kula u góry -->
    <visual>
      <origin xyz="0 0 0.54" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.088"/>
      </geometry>
      <material name="joint_ball"/>
    </visual>

    <collision>
      <origin xyz="0 0 0.28" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.52" radius="0.072"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.28" rpy="0 0 0"/>
      <mass value="9.6"/>
      <inertia ixx="0.32" ixy="0" ixz="0" iyy="0.32" iyz="0" izz="0.064"/>
    </inertial>
  </link>


  <!-- ═══════════════════════════════════════════════════
       JOINT 3 – zgięcie wokół Y
  ═══════════════════════════════════════════════════ -->

  <joint name="joint3" type="revolute">
    <parent link="link2"/>
    <child  link="link3"/>
    <origin xyz="0 0 0.54" rpy="0 0 0"/>
    <axis   xyz="0 2 0"/>
    <limit  lower="-1.57" upper="1.57" effort="160" velocity="1.5"/>
    <dynamics damping="4.8" friction="1.28"/>
  </joint>


  <!-- ═══════════════════════════════════════════════════
       LINK 3 – krótkie ramię przed przegubem
  ═══════════════════════════════════════════════════ -->

  <link name="link3">
    <visual>
      <origin xyz="0 0 0.18" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.32" radius="0.056"/>
      </geometry>
      <material name="dark_metal"/>
    </visual>
    <!-- kula u góry -->
    <visual>
      <origin xyz="0 0 0.34" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.072"/>
      </geometry>
      <material name="joint_ball"/>
    </visual>

    <collision>
      <origin xyz="0 0 0.18" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.32" radius="0.056"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.18" rpy="0 0 0"/>
      <mass value="4.8"/>
      <inertia ixx="0.16" ixy="0" ixz="0" iyy="0.16" iyz="0" izz="0.032"/>
    </inertial>
  </link>


  <!-- ═══════════════════════════════════════════════════
       JOINT WRIST – przegub nadgarstka
  ═══════════════════════════════════════════════════ -->

  <joint name="joint_wrist" type="revolute">
    <parent link="link3"/>
    <child  link="wrist_link"/>
    <origin xyz="0 0 0.34" rpy="0 0 0"/>
    <axis   xyz="0 2 0"/>
    <limit  lower="-1.57" upper="1.57" effort="100" velocity="2.0"/>
    <dynamics damping="3.2" friction="0.8"/>
  </joint>


  <!-- ═══════════════════════════════════════════════════
       WRIST LINK – walec nadgarstka
  ═══════════════════════════════════════════════════ -->

  <link name="wrist_link">
    <!-- walec -->
    <visual>
      <origin xyz="0 0 0.08" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.14" radius="0.044"/>
      </geometry>
      <material name="steel"/>
    </visual>
    <!-- pomarańczowa końcówka / palma chwytaka -->
    <visual>
      <origin xyz="0 0 0.16" rpy="0 0 0"/>
      <geometry>
        <box size="0.2 0.12 0.036"/>
      </geometry>
      <material name="accent_orange"/>
    </visual>

    <collision>
      <origin xyz="0 0 0.08" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.14" radius="0.044"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.08" rpy="0 0 0"/>
      <mass value="2"/>
      <inertia ixx="0.032" ixy="0" ixz="0" iyy="0.032" iyz="0" izz="0.032"/>
    </inertial>
  </link>


  <!-- ═══════════════════════════════════════════════════
       JOINT stały wrist → gripper
  ═══════════════════════════════════════════════════ -->

  <joint name="joint_gripper_fix" type="fixed">
    <parent link="wrist_link"/>
    <child  link="gripper_link"/>
    <origin xyz="0 0 0.18" rpy="0 0 0"/>
  </joint>


  <!-- ═══════════════════════════════════════════════════
       GRIPPER LINK – palma + dwa palce (szczęki)
  ═══════════════════════════════════════════════════ -->

  <!-- Większy chwytak: dwa szersze, dłuższe palce rozstawione na ±0.10 m,
       z PRZERWĄ w środku (~0.16 m), aby kostka wchodziła MIĘDZY palce,
       a nie była odpychana płaską bryłą kolizji. -->
  <link name="gripper_link">

    <!-- Lewy palec -->
    <visual>
      <origin xyz="-0.10 0 0.08" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.05 0.16"/>
      </geometry>
      <material name="gripper_color"/>
    </visual>
    <!-- Lewy szpic palca -->
    <visual>
      <origin xyz="-0.10 0 0.17" rpy="0 0 0"/>
      <geometry>
        <box size="0.03 0.04 0.03"/>
      </geometry>
      <material name="black"/>
    </visual>

    <!-- Prawy palec -->
    <visual>
      <origin xyz="0.10 0 0.08" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.05 0.16"/>
      </geometry>
      <material name="gripper_color"/>
    </visual>
    <!-- Prawy szpic palca -->
    <visual>
      <origin xyz="0.10 0 0.17" rpy="0 0 0"/>
      <geometry>
        <box size="0.03 0.04 0.03"/>
      </geometry>
      <material name="black"/>
    </visual>

    <!-- Poprzeczka (palma) łącząca palce u nasady -->
    <visual>
      <origin xyz="0 0 0.01" rpy="0 0 0"/>
      <geometry>
        <box size="0.24 0.05 0.03"/>
      </geometry>
      <material name="accent_orange"/>
    </visual>

    <!-- Kolizja: dwa OSOBNE palce z przerwą + cienka palma u nasady. -->
    <collision>
      <origin xyz="-0.10 0 0.08" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.05 0.16"/>
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.10 0 0.08" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.05 0.16"/>
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.005" rpy="0 0 0"/>
      <geometry>
        <box size="0.24 0.05 0.02"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.08" rpy="0 0 0"/>
      <mass value="1.2"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>


  <!-- ═══════════════════════════════════════════════════
       TCP – wirtualny punkt narzędziowy między palcami.
       To na NIM liczymy kinematykę odwrotną i dystans chwytania,
       dzięki czemu kostka trafia dokładnie między palce.
  ═══════════════════════════════════════════════════ -->

  <joint name="joint_tcp" type="fixed">
    <parent link="gripper_link"/>
    <child  link="tcp_link"/>
    <origin xyz="0 0 0.10" rpy="0 0 0"/>
  </joint>

  <link name="tcp_link">
    <inertial>
      <mass value="0.001"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
  </link>

</robot>
