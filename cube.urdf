<?xml version="1.0"?>
<robot name="cube">
  <!-- Mała kostka (0.16 m) dopasowana do zasięgu chwytaka ramienia.
       Dla bryły o boku a i masie m: I = m*(a^2 + a^2)/12. -->
  <link name="cube_link">
    <visual>
      <geometry>
        <box size="0.16 0.16 0.16"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.16 0.16 0.16"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.000853" ixy="0" ixz="0" iyy="0.000853" iyz="0" izz="0.000853"/>
    </inertial>
  </link>
</robot>
